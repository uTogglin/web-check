# We use the `wappalyzer` package only for its fingerprint JSON database, never
# its runtime — but it transitively depends on puppeteer, which would otherwise
# download a ~280MB Chromium on install. Web-Check no longer runs any headless
# browser (tech-stack is browserless; screenshots use a hosted API), so skip it.
puppeteer_skip_chromium_download=true
puppeteer_skip_download=true
