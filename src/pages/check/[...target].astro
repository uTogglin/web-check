---
import BaseLayout from '@layouts/Base.astro';
import Main from '../../client/main.tsx';
import '../../client/styles/index.css';
import { normalizeAddress } from '../../client/utils/address-type-checker';
import { withBase } from '@/utils/with-base';

// On static hosts (GitHub Pages) there is no server runtime, so this route is
// pre-rendered to a shell. Deep links like /check/example.com are served the
// same SPA via the 404.html fallback, which boots React and routes client-side.
export const prerender = import.meta.env.PUBLIC_BUILD_STATIC === 'true';

// Pre-render only the base /check shell; the rest-param targets are handled
// client-side (and via 404.html on static hosts). Ignored in server builds.
export function getStaticPaths() {
  return [{ params: { target: undefined } }];
}

// Server-side ?url= redirect only runs on the server (Fly). On static builds the
// inline <script> below performs the same redirect client-side.
if (!import.meta.env.PUBLIC_BUILD_STATIC) {
  const { search } = new URL(Astro.request.url);
  const searchUrl = new URLSearchParams(search).get('url');
  if (searchUrl) {
    const target = normalizeAddress(searchUrl);
    if (target) Astro.redirect(`/check/${target}`);
  }
}

const { target } = Astro.params;
const pageTitle = target ? `${target} | Web Check` : 'Web Check';
---

<BaseLayout preloadBodyFont={false} title={pageTitle}>
  <link
    slot="head"
    href={withBase('fonts/PTMono-Regular.woff2')}
    as="font"
    rel="preload"
    type="font/woff2"
    crossorigin="anonymous"
  />
  <Main client:only="react" />
</BaseLayout>

<script>
  import { normalizeAddress } from '../../client/utils/address-type-checker';
  import { withBase } from '@/utils/with-base';

  const searchParams = new URL(window.location.href).searchParams;
  if (searchParams.has('url')) {
    const target = normalizeAddress(searchParams.get('url') || '');
    if (target) window.location.href = withBase(`check/${target}`);
  }

  const form = document.querySelector<HTMLFormElement>('form');
  if (form) {
    form.addEventListener('submit', function (event: Event) {
      event.preventDefault();
      const input = (this as HTMLFormElement).querySelector<HTMLInputElement>('input[name="url"]');
      const target = normalizeAddress(input?.value);
      if (target) window.location.href = withBase(`check/${target}`);
    });
  }
</script>
